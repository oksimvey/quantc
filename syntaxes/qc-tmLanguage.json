{
  "scopeName": "source.qc",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#builtins" },
    { "include": "#numbers" },
    { "include": "#class-names" },
    { "include": "#function-calls" },
    { "include": "#operators" },
    { "include": "#identifiers" }
  ],

  "repository": {

    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.qc",
          "match": "//.*$"
        },
        {
          "name": "comment.block.qc",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },

    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.qc",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.qc",
              "match": "\\\\."
            }
          ]
        }
      ]
    },

    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.qc",
          "match": "\\b(function|address|pointing|reference|wait|await|return|if|else|while|for|true|false|continue|break|unsigned|switch|case|default|public|private|mutable|constexpr|abstract|class|const|global|local|this|new|try|throw|catch|null|super|instanceof|and|or|not|delete|extends|pointer|override|enum)\\b"
        }
      ]
    },

    "types": {
      "patterns": [
        {
          "name": "storage.type.qc",
          "match": "\\b(byte|short|int|long|float|double|array|hashmap|list|char|string|boolean|void)\\b"
        }
      ]
    },

    "builtins": {
      "patterns": [
        {
          "name": "support.function.builtin.qc",
          "match": "\\b(print|sqrt|abs|sin|cos|tan|min|max|pow|atan|atan2|acos|asin|ceil|floor|exp|log|log10|cosh|sinh|tanh|acosh|asinh|atanh)\\b"
        }
      ]
    },

    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.qc",
          "match": "\\b\\d+(\\.\\d+)?\\b"
        }
      ]
    },

    "class-names": {
      "patterns": [
        {
          "name": "entity.name.type.class.qc",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        }
      ]
    },

    "function-calls": {
      "patterns": [
        {
          "name": "entity.name.function.qc",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*(?=\\s*\\()"
        }
      ]
    },

    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.qc",
          "match": "(==|!=|<=|>=|\\+\\+|--|&&|\\|\\||<<|>>|->|[+\\-*/%=!<>&|.,;:{}\\[\\]()])"
        }
      ]
    },

    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.qc",
          "match": "\\b[a-z_][A-Za-z0-9_]*\\b"
        }
      ]
    }
  }
}