{
  "scopeName": "source.qc",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    {"include": "#angle-brackets"},

    { "include": "#control-flow" },
    { "include": "#declarations" },
    { "include": "#modifiers" },
    { "include": "#async" },
    { "include": "#operators-words" },
    { "include": "#literals" },

    { "include": "#types-primitive" },
    { "include": "#types-collections" },

    { "include": "#builtins-io" },
    { "include": "#builtins-math" },
    { "include": "#builtins-memory" },

    { "include": "#numbers" },
    { "include": "#class-names" },
    { "include": "#function-calls" },
    { "include": "#operators" },
    { "include": "#identifiers" }
  ],

  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.qc",
          "match": "//.*$"
        },
        {
          "name": "comment.block.qc",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },

    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.qc",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.qc",
              "match": "\\\\."
            }
          ]
        }
      ]
    },

    "control-flow": {
      "patterns": [
        {
          "name": "keyword.control.flow.qc",
          "match": "\\b(if|else|while|for|switch|case|default|break|continue|return|try|catch|throw)\\b"
        }
      ]
    },

    "declarations": {
      "patterns": [
        {
          "name": "keyword.declaration.qc",
          "match": "\\b(function|class|enum|extends|new|delete|override)\\b"
        }
      ]
    },

    "modifiers": {
      "patterns": [
        {
          "name": "storage.modifier.scope.qc",
          "match": "\\b(global|instance)\\b"
        },
        {
          "name": "storage.modifier.access.qc",
          "match": "\\b(public|private|protected)\\b"
        },
        {
          "name": "storage.modifier.memory.qc",
          "match": "\\b(const|mutable|unsigned|raw|shared|unique|pointer|reference|instanceof|this)\\b"
        }
      ]
    },

    "async": {
      "patterns": [
        {
          "name": "keyword.control.async.qc",
          "match": "\\b(wait|await)\\b"
        }
      ]
    },

    "operators-words": {
      "patterns": [
        {
          "name": "keyword.operator.word.qc",
          "match": "\\b(and|or|not)\\b"
        }
      ]
    },

    "literals": {
      "patterns": [
        {
          "name": "constant.language.qc",
          "match": "\\b(true|false|null)\\b"
        }
      ]
    },

    "types-primitive": {
      "patterns": [
        {
          "name": "keyword.declaration.q",
          "match": "\\b(int|float|double|char|string|boolean|void|byte|short|long)\\b"
        }
      ]
    },

    "types-collections": {
      "patterns": [
        {
          "name": "entity.name.type.container.qc",
          "match": "\\b(hashmap|list|array)\\b"
        }
      ]
    },

    "builtins-io": {
      "patterns": [
        {
          "name": "support.function.builtin.io.qc",
          "match": "\\b(print)\\b"
        }
      ]
    },

    "builtins-math": {
      "patterns": [
        {
          "name": "support.function.builtin.math.qc",
          "match": "\\b(sqrt|abs|sin|cos|tan|min|max|pow|log|exp|floor|ceil)\\b"
        }
      ]
    },

    "builtins-memory": {
      "patterns": [
        {
          "name": "support.function.builtin.memory.qc",
          "match": "\\b(pointing|address)\\b"
        }
      ]
    },

    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.qc",
          "match": "\\b\\d+(\\.\\d+)?\\b"
        }
      ]
    },

    "class-names": {
      "patterns": [
        {
          "name": "entity.name.type.class.qc",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        }
      ]
    },

    "function-calls": {
      "patterns": [
        {
          "name": "entity.name.function.qc",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*(?=\\s*\\()"
        }
      ]
    },
    "angle-brackets": {
      "patterns": [
        {
          "name": "entity.name.type.container.qc",
          "match": "[<>]"
        }
      ]
    },

    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.qc",
          "match": "(==|!=|<=|>=|\\+\\+|--|&&|\\|\\||<<|>>|->|[+\\-*/%=!&|.,;:{}\\[\\]()])"
        }
      ]
    },

    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.qc",
          "match": "\\b[a-z_][A-Za-z0-9_]*\\b"
        }
      ]
    }
  }
}