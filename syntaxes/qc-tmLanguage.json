{
  "scopeName": "source.qc",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#function-calls" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.qc",
          "match": "//.*$"
        },
        {
          "name": "comment.block.qc",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.qc",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.qc",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.qc",
          "match": "\\b(func|let|return|print|if|else|while|for|true|false|for|continue|break|switch|case|default)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.qc",
          "match": "\\b(byte|short|int|long|float|double|unsbyte|unsshort|unsint|unslong|unsfloat|unsdouble|char|string|bool|void)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.qc",
          "match": "\\b\\d+(\\.\\d+)?\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.qc",
          "match": "(==|!=|<=|>=|&&|\\|\\||[+\\-*/%=!<>&|.,;:{}\\[\\]\\√\\()])"
        }
      ]
    },
    "function-calls": {
      "patterns": [
        {
          "name": "entity.name.function.qc",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*(?=\\s*\\()"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.qc",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
        }
      ]
    }
  }
}
