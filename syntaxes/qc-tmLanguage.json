{
  "name": "QC",
  "scopeName": "source.qc",
  "fileTypes": [
    "qc"
  ],

  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },

    { "include": "#keywords" },
    { "include": "#types" },

    { "include": "#functionDefinitions" },
    { "include": "#functions" },
    { "include": "#structures" },
    { "include": "#generics" },

    { "include": "#operators" },
    { "include": "#punctuation" }
  ],

  "repository": {
    

    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.qc",
          "match": "//.*$"
        },
        {
          "name": "comment.block.qc",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },

    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.qc",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.qc",
              "match": "\\\\(?:[btnfr\\\"'\\\\]|x[0-9A-Fa-f]{2}|u[0-9A-Fa-f]{4})"
            }
          ]
        },
        {
          "name": "string.quoted.single.qc",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.qc",
              "match": "\\\\(?:[btnfr\\\"'\\\\]|x[0-9A-Fa-f]{2}|u[0-9A-Fa-f]{4})"
            }
          ]
        }
      ]
    },

    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.qc",
          "match": "\\b0[xX][0-9A-Fa-f]+\\b"
        },
        {
          "name": "constant.numeric.binary.qc",
          "match": "\\b0[bB][01]+\\b"
        },
        {
          "name": "constant.numeric.float.qc",
          "match": "\\b(?:\\d+\\.\\d*|\\.\\d+)(?:[eE][+-]?\\d+)?\\b"
        },
        {
          "name": "constant.numeric.integer.qc",
          "match": "\\b\\d+\\b"
        }
      ]
    },

    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.qc",
          "match": "\\b(?:if|else|for|while|continue|break|return|switch|case|default|try|catch|throw|await|wait|and|or|not|this|instanceof)\\b"
        },
        {
          "name": "storage.modifier.qc",
          "match": "\\b(?:public|protected|private|static|member|const|mutable|override|extends|super)\\b"
        },
        {
          "name": "storage.type.qc",
          "match": "\\b(?:function|operator|enum|class|void|auto|task)\\b"
        },
        {
          "name": "constant.language.qc",
          "match": "\\b(?:true|false|null)\\b"
        }
      ]
    },

    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.qc",
          "match": "\\b(?:byte|short|int|long|ubyte|ushort|uint|ulong|char|string|boolean)\\b"
        },
        {
          "name": "support.type.container.qc",
          "match": "\\b(?:Array|List|HashMap|Pointer|UniquePointer|SharedPointer|Reference)\\b"
        }
      ]
    },

    "functionDefinitions": {
      "patterns": [
        {
          "name": "meta.function.definition.qc",
          "begin": "\\b(function)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
          "beginCaptures": {
            "1": { "name": "storage.type.function.qc" },
            "2": { "name": "entity.name.function.qc" }
          },
          "end": "(?=\\{)",
          "patterns": [
            { "include": "#comments" },
            { "include": "#strings" },
            { "include": "#numbers" },
            { "include": "#keywords" },
            { "include": "#types" },
            { "include": "#operators" },
            { "include": "#punctuation" },
            { "include": "#generics" },
            { "include": "#functions" }
          ]
        }
      ]
    },

    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.call.qc",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b(?=\\s*\\()"
        }
      ]
    },
"structures": {
  "patterns": [
    {
      "name": "meta.class.qc",
      "begin": "\\b(class)\\s+([A-Za-z_][A-Za-z0-9_]*)(?:\\s+(extends)\\s+([A-Za-z_][A-Za-z0-9_]*))?\\s*\\{",
      "beginCaptures": {
        "1": { "name": "storage.type.class.qc" },
        "2": { "name": "entity.name.type.class.qc" },
        "3": { "name": "keyword.inheritance.qc" },
        "4": { "name": "entity.other.inherited-class.qc" }
      },
      "end": "\\}",
      "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#numbers" },
        { "include": "#keywords" },
        { "include": "#types" },
        { "include": "#operators" },
        { "include": "#punctuation" },

        { "include": "#classMembers" },
        { "include": "#functions" },
        { "include": "#generics" }
      ]
    }
  ]
},

    "generics": {
      "patterns": [
        {
          "name": "meta.generic.qc",
          "begin": "(?<=\\b[A-Za-z_][A-Za-z0-9_]*\\s*)<",
          "end": ">",
          "patterns": [
            {
              "name": "support.type.generic.qc",
              "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
            },
            {
              "name": "punctuation.separator.generic.qc",
              "match": ","
            },
            {
              "name": "keyword.operator.generic.qc",
              "match": "\\?|&"
            },
            { "include": "#comments" },
            { "include": "#strings" },
            { "include": "#numbers" }
          ]
        }
      ]
    },

    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.qc",
          "match": "\\*\\*=|==|!=|<=|>=|\\+=|-=|\\*=|/=|%=|=|\\+\\+|--"
        },
        {
          "name": "keyword.operator.logical.qc",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.bitwise.qc",
          "match": "<<|\\^|&|\\|"
        },
        {
          "name": "keyword.operator.arithmetic.qc",
          "match": "\\*\\*|[+\\-*/%<>]"
        }
      ]
    },

    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.qc",
          "match": "[(),.;:]"
        },
        {
          "name": "punctuation.section.brackets.qc",
          "match": "[\\[\\]{}]"
        },
        {
          "name": "punctuation.accessor.qc",
          "match": "\\."
        }
      ]
    }

  }
}